{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "~/.config/fastfetch/cachyos_logo.txt",
        "type": "file",
        "color": {
            "1": "green",
            "2": "cyan"
        },
        "padding": {
            "top": 1,
            "right": 4,
            "left": 3
        }
    },
    "display": {
        "separator": " 󰁔 ",
        "color": {
            "keys": "green",
            "title": "cyan"
        },
        "bar": {
            "width": 12,
            "char": {
                "elapsed": "█",
                "total": "░"
            }
        }
    },
    "modules": [
        "title",
        "separator",
        {
            "type": "os",
            "key": "󰣇 distro ",
            "keyColor": "green"
        },
        {
            "type": "kernel",
            "key": " kernel ",
            "keyColor": "green"
        },
        {
            "type": "uptime",
            "key": "󰅐 uptime ",
            "keyColor": "green"
        },
        {
            "type": "command",
            "key": "󱦟 os age ",
            "keyColor": "green",
            "text": "printf \"\\e[0m%s days\\e[0m\" \"$(( ($(date +%s) - $(stat -c %W /)) / 86400 ))\""
        },
        "break",
        {
            "type": "wm",
            "key": " wm     ",
            "keyColor": "cyan"
        },
        {
            "type": "terminal",
            "key": " term   ",
            "keyColor": "cyan"
        },
        {
            "type": "shell",
            "key": " shell  ",
            "keyColor": "cyan"
        },
        "break",
        {
            "type": "cpu",
            "key": "󰍛 cpu    ",
            "keyColor": "magenta"
        },
        {
            "type": "memory",
            "key": " ram    ",
            "keyColor": "magenta",
            "percent": {
                "type": 3
            }
        },
        {
            "type": "disk",
            "key": "󰉉 disk   ",
            "keyColor": "magenta",
            "percent": {
                "type": 3
            }
        },
        "break",
        {
            "type": "colors",
            "key": " colors ",
            "symbol": "circle"
        }
    ]
}
