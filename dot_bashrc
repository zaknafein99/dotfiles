# .bashrc - Main Orchestrator

# Prevent double sourcing
if [[ -n "$_BASHRC_SOURCED" ]]; then return; fi
_BASHRC_SOURCED=1

# --- GHOSTTY FIX ---
# Disable Ghostty's auto-injected shell integration to prevent duplicate prompts
# as we are handling the prompt manually with Starship and ble.sh.
export GHOSTTY_SHELL_INTEGRATION=none

# 1. System-wide definitions (Sourced early)
if [ -f /etc/bashrc ]; then
    . /etc/bashrc
fi

# 2. Early Interactive Setup
if [[ $- == *i* ]]; then
    # Limpiamos rastro de prompts previos
    PS1=""
    unset PROMPT_COMMAND
    declare -a PROMPT_COMMAND
fi

# 3. Load ble.sh (without attaching yet)
[[ $- == *i* ]] && source -- "$HOME/.local/share/blesh/ble.sh" --attach=none --rcfile "$HOME/.blerc"

# 4. Source modular configs
BASH_CONF_DIR="$HOME/.config/bash"

source "$BASH_CONF_DIR/env.bash"
source "$BASH_CONF_DIR/aliases.bash"
source "$BASH_CONF_DIR/functions.bash"

# Sourcing .bashrc.d if it exists (legacy support)
if [ -d ~/.bashrc.d ]; then
    for rc in ~/.bashrc.d/*; do
        [ -f "$rc" ] && . "$rc"
    done
fi

source "$BASH_CONF_DIR/tools.bash"
source "$BASH_CONF_DIR/prompt.bash"

# 5. Logo and Final Attach
if [[ $- == *i* ]]; then
    # El logo antes de ble-attach
    fastfetch
    
    if [[ ${BLE_VERSION-} ]]; then
      PS1=""
      ble-attach
    fi
fi

# Hermes TUI mode
export HERMES_TUI=1
# Added by Antigravity CLI installer
export PATH="/home/isma/.local/bin:$PATH"

#THIS MUST BE AT THE END OF THE FILE FOR SDKMAN TO WORK!!!
export SDKMAN_DIR="/home/isma/.sdkman"
[[ -s "/home/isma/.sdkman/bin/sdkman-init.sh" ]] && source "/home/isma/.sdkman/bin/sdkman-init.sh"

# Added by LM Studio CLI (lms)
export PATH="$PATH:/home/isma/.lmstudio/bin"
# End of LM Studio CLI section

